rules_version = '2';
// where to next? — Cloud Storage rules
// รูปทั้งหมดเก็บใต้ users/{uid}/... เจ้าของเขียนได้ อ่านสาธารณะ (รูปในตอนที่เผยแพร่ต้องเข้าถึงได้)
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/backup.json {
      allow read, write: if request.auth != null && request.auth.uid == uid
                   && (request.resource == null || request.resource.size < 45 * 1024 * 1024);
    }
    match /users/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 8 * 1024 * 1024            // <= 8MB/ไฟล์
                   && request.resource.contentType.matches('image/.*|application/pdf');
    }
  }
}
